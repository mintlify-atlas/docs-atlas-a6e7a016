  "keyFeatures": [
    "Dead-man's switch detection for missed CronJob schedules",
    "SLA tracking with success rates and duration percentiles (P50/P95/P99)",
    "Intelligent alerting with pod logs, events, and suggested fixes",
    "Multiple alert channels (Slack, PagerDuty, webhook, email)",
    "Built-in web dashboard with charts and heatmaps",
    "Prometheus metrics export",
    "Maintenance window support",
    "Performance regression detection"
  ],
  "publicApiSurface": [
    "CronJobMonitor CRD (guardian.illenium.net/v1alpha1)",
    "AlertChannel CRD (guardian.illenium.net/v1alpha1)",
    "REST API endpoints (/api/monitors, /api/cronjobs, /api/executions)",
    "Prometheus metrics endpoint (/metrics)",
    "Web dashboard UI (port 8080)",
    "Helm chart (oci://ghcr.io/illeniumstudios/charts/cronjob-guardian)"
  ]
